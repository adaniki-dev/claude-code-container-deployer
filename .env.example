# Required
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
ENCRYPTION_KEY=your-32-byte-hex-key  # Generate with: openssl rand -hex 32
ALLOWED_USER_IDS=123456789  # Comma-separated Telegram user IDs

# Runtime mode: "docker" for local dev, "k8s" for Kubernetes
RUNTIME_MODE=docker

# Docker mode settings
RUNNER_CONTAINER_NAME=claude-runner
DOCKER_NETWORK=claude-code-on-kluster_default
RUNNER_IMAGE=claude-code-on-kluster-runner:latest

# Database
DB_PATH=/data/bot.db
LOG_LEVEL=info

# Claude Authentication (choose one approach)
# Option 1: OAuth token from `claude setup-token` (limited scopes — no remote-control)
CLAUDE_CODE_OAUTH_TOKEN=

# Option 2: Full credentials file from `claude auth login` (recommended — full scopes)
CLAUDE_CREDENTIALS_PATH=/path/to/your/.claude/.credentials.json
CLAUDE_CONFIG_PATH=/path/to/your/.claude.json
